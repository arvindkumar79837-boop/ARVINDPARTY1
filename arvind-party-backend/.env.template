# ═══════════════════════════════════════════════════════════════════════════
# FILE: lib/arvind-party-backend/.env.template
# ARVIND PARTY - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual credentials
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/arvind_party?retryWrites=true&w=majority
REDIS_URL=redis://:password@localhost:6379

# ─────────────────────────────────────────────────────────────────────────
# JWT & SECURITY
# ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-at-least-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
DEVICE_SECRET=your-device-secret-key-for-signing

# ─────────────────────────────────────────────────────────────────────────
# FIREBASE ADMIN SDK
# ─────────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=arvind-party-production
FIREBASE_PRIVATE_KEY_ID=xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@arvind-party-production.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=xxxxx
FIREBASE_DATABASE_URL=https://arvind-party-production.firebaseio.com

# ─────────────────────────────────────────────────────────────────────────
# RAZORPAY PAYMENT GATEWAY
# ─────────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxx

# ─────────────────────────────────────────────────────────────────────────
# AGORA REAL-TIME COMMUNICATION
# ─────────────────────────────────────────────────────────────────────────
AGORA_APP_ID=xxxxx
AGORA_APP_CERTIFICATE=xxxxx

# ─────────────────────────────────────────────────────────────────────────
# STORAGE & CDN
# ─────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# ─────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (NODEMAILER)
# ─────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@arvindparty.com

# ─────────────────────────────────────────────────────────────────────────
# TWILIO (SMS)
# ─────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ─────────────────────────────────────────────────────────────────────────
# CORS & SECURITY
# ─────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.arvindparty.com,https://admin.arvindparty.com,http://localhost:3000
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_CREDENTIALS=true

# ─────────────────────────────────────────────────────────────────────────
# API ENDPOINTS
# ─────────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.arvindparty.com
ADMIN_URL=https://admin.arvindparty.com
API_BASE_URL=https://api.arvindparty.com
API_INTERNAL_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ─────────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────────────────────────────────────────────────────────────────
# AWS (optional, for deployment)
# ─────────────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_S3_BUCKET=arvind-party-uploads

# ─────────────────────────────────────────────────────────────────────────
# ADMIN PANEL
# ─────────────────────────────────────────────────────────────────────────
ADMIN_PANEL_JWT_SECRET=admin-jwt-secret-change-this
ADMIN_PANEL_SESSION_TIMEOUT=3600